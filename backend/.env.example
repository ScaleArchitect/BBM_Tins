APP_ENV=local

# DATABASE_URL is the app connection. In Docker Compose it is overridden per
# service: the app (api/worker/scheduler) connects as the NON-superuser, RLS-
# enforced role `tin_app`; migrations run as the owner `tin`. For host-only dev
# the owner URL below is fine (RLS is proven via the container + integration tests).
DATABASE_URL=postgresql+asyncpg://tin:tin@db:5432/tin
# Owner/admin connection for migrations + platform cross-tenant path (bypasses RLS).
DATABASE_ADMIN_URL=postgresql+asyncpg://tin:tin@db:5432/tin
REDIS_URL=redis://redis:6379/0

STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://storage:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
STORAGE_BUCKET=tin-certs

OCR_PROVIDER=local
EMAIL_PROVIDER=smtp
SMTP_HOST=mail
SMTP_PORT=1025
EMAIL_FROM="TIN Portal <no-reply@tinportal.dev>"

QUEUE_PROVIDER=arq_redis

# JWT: RS256 with keys from Key Vault in prod. If these PEM files are absent
# locally, an ephemeral keypair is generated at startup (dev convenience only).
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
JWT_ISSUER=tin-portal
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

OTP_PEPPER=change-me-32-bytes
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=3
OTP_LOCKOUT_SECONDS=1800

# Admin login throttling / lockout.
LOGIN_MAX_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_SECONDS=900
LOGIN_LOCKOUT_SECONDS=900

# Public base URL used to build invitation / set-password links.
PUBLIC_BASE_URL=http://localhost

# Dev bootstrap: first platform admin seeded by `python -m app.seed` (compose
# runs this as a one-shot). Provisioned by infra in production — change these.
PLATFORM_BOOTSTRAP_EMAIL=platform@example.com
PLATFORM_BOOTSTRAP_PASSWORD=ChangeMe!Platform1

MAX_UPLOAD_MB=10
SIGNED_URL_TTL=300

GROUP_CERT_POLICY=REJECT
TIN_DERIVATION_MODE=TRN_FIRST_10
RETENTION_MONTHS_DEFAULT=24

NEXT_PUBLIC_API_BASE=/api/v1
